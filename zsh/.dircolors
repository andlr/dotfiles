# I couldn't find any light themes for dircolors, so I've given up and generated one with Claude.
# Result looks quite decent.
#
# Uses Catppuccin Latte palette (approximate 256-color / truecolor ANSI):
#   Rosewater  #dc8a78  → 216
#   Flamingo   #dd7878  → 210
#   Pink       #ea76cb  → 213
#   Mauve      #8839ef  → 99
#   Red        #d20f39  → 160
#   Maroon     #e64553  → 167
#   Peach      #fe640b  → 208
#   Yellow     #df8e1d  → 178
#   Green      #40a02b  → 34
#   Teal       #179299  → 30
#   Sky        #04a5e5  → 39
#   Sapphire   #209fb5  → 31
#   Blue       #1e66f5  → 27
#   Lavender   #7287fd  → 105
#   Text       #4c4f69  → 238
#   Subtext1   #5c5f77  → 240
#   Subtext0   #6c6f85  → 242
#   Overlay2   #7c7f93  → 244
#   Overlay1   #8c8fa1  → 245
#   Overlay0   #9ca0b0  → 246
#   Surface2   #acb0be  → 247
#   Surface1   #bcc0cc  → 250
#   Surface0   #ccd0da  → 252
#   Base       #eff1f5  → 255
#   Mantle     #e6e9ef  → 254
#   Crust      #dce0e8  → 253

TERM Eterm
TERM ansi
TERM color-xterm
TERM con132x25
TERM con132x30
TERM con132x43
TERM con132x60
TERM con80x25
TERM con80x28
TERM con80x30
TERM con80x43
TERM con80x50
TERM con80x60
TERM cons25
TERM console
TERM cygwin
TERM dtterm
TERM gnome
TERM gnome-256color
TERM hurd
TERM jfbterm
TERM konsole
TERM konsole-256color
TERM kterm
TERM linux
TERM linux-c
TERM mach-color
TERM mlterm
TERM putty
TERM putty-256color
TERM rxvt
TERM rxvt-256color
TERM rxvt-cygwin
TERM rxvt-cygwin-native
TERM rxvt-unicode
TERM rxvt-unicode-256color
TERM rxvt-unicode256
TERM screen
TERM screen-256color
TERM screen-256color-bce
TERM screen-bce
TERM screen-w
TERM screen.Eterm
TERM screen.rxvt
TERM screen.linux
TERM st
TERM st-256color
TERM terminator
TERM tmux
TERM tmux-256color
TERM vt100
TERM xterm
TERM xterm-16color
TERM xterm-256color
TERM xterm-88color
TERM xterm-color
TERM xterm-debian
TERM xterm-kitty

# ==========================================
# CORE FILE TYPES
# ==========================================

# Normal file — Text (4c4f69 / 238)
NORMAL 00;38;5;238

# Regular file — same as NORMAL
FILE 00;38;5;238

# Reset to normal
RESET 0

# Directory — Blue (1e66f5 / 27), bold
DIR 01;38;5;27

# Symbolic link — Sky (04a5e5 / 39)
LINK 00;38;5;39

# Multihardlink
MULTIHARDLINK 00;38;5;246

# Pipe / FIFO — Yellow (df8e1d / 178)
FIFO 00;38;5;178

# Socket — Mauve (8839ef / 99)
SOCK 00;38;5;99

# Door (Solaris)
DOOR 00;38;5;99

# Block device — Peach (fe640b / 208), bold
BLK 01;38;5;208

# Character device — Peach (fe640b / 208)
CHR 00;38;5;208

# Orphaned symlink — Red (d20f39 / 160) on Base
ORPHAN 00;38;5;160

# Missing file pointed to by symlink
MISSING 00;38;5;160

# Setuid (u+s) — Red bg
SETUID 00;38;5;255;48;5;160

# Setgid (g+s) — Yellow bg
SETGID 00;38;5;238;48;5;178

# Sticky + other-writable — Teal bg
STICKY_OTHER_WRITABLE 00;38;5;255;48;5;30

# Other-writable (not sticky) — Sapphire bg
OTHER_WRITABLE 00;38;5;238;48;5;31

# Sticky (not other-writable) — Lavender bg
STICKY 00;38;5;255;48;5;105

# Executable — Green (40a02b / 34), bold
EXEC 01;38;5;34

